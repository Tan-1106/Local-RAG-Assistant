# ==============================================================================
# LEGAL ASSISTANT - CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DOCKER & SYSTEM PORTS
# Ports mapped from the Docker containers to the host machine.
# ------------------------------------------------------------------------------
PORT_OLLAMA=11434
PORT_QDRANT=6333
PORT_BACKEND=8000
PORT_FRONTEND=3000

# ------------------------------------------------------------------------------
# 2. LOCAL AI ENGINE (Ollama)
# - OLLAMA_BASE_URL: Internal Docker network URL for backend to connect to Ollama.
# - OLLAMA_MODEL: Name of the local LLM used for inference.
#   Recommended for Vietnamese: qwen2.5:7b, llama3.1:8b, or vinallama:7b.
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# ------------------------------------------------------------------------------
# 3. VECTOR DATABASE CONFIGURATION (Qdrant)
# - QDRANT_URL: Internal Docker network URL for backend to connect to Qdrant.
# - QDRANT_COLLECTION_NAME: Name of the collection storing legal document vectors.
# ------------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=legal_documents

# ------------------------------------------------------------------------------
# 4. BACKEND RUNTIME (FastAPI + LlamaIndex)
# - HF_HOME: HuggingFace cache directory (mounted to a named volume to avoid downloading again).
# - EMBEDDING_MODEL: The embedding model used to vectorize documents and queries.
#   Recommended model for Vietnamese documents: dangvantuan/vietnamese-document-embedding.
# - EMBEDDING_DIMENSION: Vector dimensions produced by the model (768 for dangvantuan/vietnamese-document-embedding).
# ------------------------------------------------------------------------------
HF_HOME=/root/.cache/huggingface
HF_TOKEN=your_huggingface_token_here
EMBEDDING_MODEL=dangvantuan/vietnamese-document-embedding
EMBEDDING_DIMENSION=768

# ------------------------------------------------------------------------------
# 5. FRONTEND CONFIGURATION (React + Vite)
# - VITE_API_URL: The API URL accessed by the user's browser (client-side).
#   Note: Since this runs in the browser, it must communicate via localhost/host IP,
#   NOT the internal docker service name "http://backend:8000".
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
