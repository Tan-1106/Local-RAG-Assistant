# ==============================================================================
# LEGAL ASSISTANT - CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DOCKER & SYSTEM PORTS
# Ports mapped from the Docker containers to the host machine.
# ------------------------------------------------------------------------------
PORT_OLLAMA=11434
PORT_QDRANT=6333
PORT_BACKEND=8000
PORT_FRONTEND=3000

# ------------------------------------------------------------------------------
# 2. LOCAL AI ENGINE (Ollama)
# - OLLAMA_BASE_URL: Internal Docker network URL for backend to connect to Ollama.
# - OLLAMA_MODEL: Name of the local LLM used for inference.
#   Recommended for Vietnamese: qwen2.5:7b, llama3.1:8b, or vinallama:7b.
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# ------------------------------------------------------------------------------
# 3. VECTOR DATABASE CONFIGURATION (Qdrant)
# - QDRANT_URL: Internal Docker network URL for backend to connect to Qdrant.
# - QDRANT_COLLECTION_NAME: Name of the collection storing legal document vectors.
# ------------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6334
QDRANT_COLLECTION_NAME=legal_documents
QDRANT_PREFER_GRPC=true

# ------------------------------------------------------------------------------
# 4. BACKEND RUNTIME (FastAPI + LlamaIndex)
# - HF_HOME: HuggingFace cache directory (mounted to a named volume to avoid downloading again).
# - EMBEDDING_MODEL: The embedding model used to vectorize documents and queries.
#   Recommended model for Vietnamese documents: dangvantuan/vietnamese-document-embedding.
# - EMBEDDING_DIMENSION: Vector dimensions produced by the model (768 for dangvantuan/vietnamese-document-embedding).
# - ALLOWED_ORIGINS: List of origins allowed to make CORS requests to the backend (comma-separated).
# - DATA_DIR: Dynamic path where uploaded legal documents are stored for ingestion.
# - DOCSTORE_PATH: Dynamic path where the LlamaIndex hierarchical docstore is persisted.
# ------------------------------------------------------------------------------
HF_HOME=/root/.cache/huggingface
HF_TOKEN=your_huggingface_token_here
EMBEDDING_MODEL=dangvantuan/vietnamese-document-embedding
EMBEDDING_DIMENSION=768
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATA_DIR=/app/data
DOCSTORE_PATH=/app/storage/docstore.json


# ------------------------------------------------------------------------------
# 5. FRONTEND CONFIGURATION (React + Vite)
# - VITE_API_URL: Optional external API origin for standalone frontend development.
#   Docker production-style builds use same-origin /api through Nginx.
# ------------------------------------------------------------------------------
VITE_API_URL=

# ------------------------------------------------------------------------------
# 6. DATABASE & AUTHENTICATION
# - DATABASE_URL: SQLite or PostgreSQL connection string.
# - JWT_SECRET_KEY: Secret key for signing JWT tokens. (REQUIRED, do not leave empty)
# - JWT_ALGORITHM: Encoding algorithm for JWT.
# - APP_ENV: Runtime environment mode (development, test, or production).
# - TRUST_PROXY_HEADERS: Set to true if the application runs behind a reverse proxy (e.g., Nginx).
# - ACCESS_TOKEN_EXPIRE_MINUTES: Expiration time for JWT access tokens in minutes.
# - REFRESH_TOKEN_EXPIRE_DAYS: Expiration time for JWT refresh tokens in days.
# - AUTH_COOKIE_SECURE: Set to true in production to ensure cookies are sent over HTTPS only.
# - AUTH_COOKIE_SAMESITE: Cookie SameSite policy (lax, strict, or none).
# - SUPER_ADMIN_USERNAME: Username for the auto-created system super administrator. (REQUIRED)
# - SUPER_ADMIN_PASSWORD: Password for the auto-created system super administrator. (REQUIRED)
# ------------------------------------------------------------------------------
DATABASE_URL=sqlite:////app/data/db.sqlite3
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
APP_ENV=development
TRUST_PROXY_HEADERS=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
SUPER_ADMIN_USERNAME=Admin
SUPER_ADMIN_PASSWORD=admin_secure_password_here

# ------------------------------------------------------------------------------
# 7. UPLOAD POLICY
# Configuration for document upload limits on the admin panel.
# - UPLOAD_MAX_FILES: Maximum number of files allowed in a single upload batch.
# - UPLOAD_MAX_FILE_MB: Maximum allowed size for an individual file (in MB).
# - UPLOAD_MAX_TOTAL_MB: Maximum aggregate size for all files in a single batch (in MB).
# ------------------------------------------------------------------------------
UPLOAD_MAX_FILES=10
UPLOAD_MAX_FILE_MB=10
UPLOAD_MAX_TOTAL_MB=50

# ------------------------------------------------------------------------------
# 8. REDIS & RATE LIMITS
# Redis connection and rate limit configurations for API endpoints.
# - REDIS_URL: Connection URL for the Redis server.
# - RATE_LIMIT_LOGIN_IP_PER_MINUTE: Login requests allowed per IP address per minute.
# - RATE_LIMIT_LOGIN_USERNAME_PER_15_MINUTES: Login requests allowed per username per 15 minutes.
# - RATE_LIMIT_REGISTER_IP_PER_HOUR: Registration requests allowed per IP address per hour.
# - RATE_LIMIT_CHAT_USER_PER_MINUTE: Chat requests allowed per user per minute.
# - RATE_LIMIT_UPLOAD_ADMIN_PER_10_MINUTES: Ingestion upload requests allowed per admin per 10 minutes.
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_LOGIN_IP_PER_MINUTE=5
RATE_LIMIT_LOGIN_USERNAME_PER_15_MINUTES=10
RATE_LIMIT_REGISTER_IP_PER_HOUR=3
RATE_LIMIT_CHAT_USER_PER_MINUTE=20
RATE_LIMIT_UPLOAD_ADMIN_PER_10_MINUTES=5

# ------------------------------------------------------------------------------
# 9. REDIS QUEUE (RQ) WORKER & RAG LOCKS
# Background task worker and concurrency control for legal document ingestion.
# - RQ_QUEUE_NAME: Name of the Redis Queue used for ingestion tasks.
# - RQ_JOB_TIMEOUT_SECONDS: Maximum execution time for a background job.
# - RQ_RESULT_TTL_SECONDS: Time-to-live for completed job results (in Redis).
# - RQ_FAILURE_TTL_SECONDS: Time-to-live for failed job records (in Redis).
# - RAG_WRITE_LOCK_TIMEOUT_SECONDS: Maximum time a write lock is held during ingestion.
# - RAG_WRITE_LOCK_WAIT_SECONDS: Time to wait when trying to acquire a write lock.
# ------------------------------------------------------------------------------
RQ_QUEUE_NAME=document-ingestion
RQ_JOB_TIMEOUT_SECONDS=3600
RQ_RESULT_TTL_SECONDS=86400
RQ_FAILURE_TTL_SECONDS=604800
RAG_WRITE_LOCK_TIMEOUT_SECONDS=3900
RAG_WRITE_LOCK_WAIT_SECONDS=60
